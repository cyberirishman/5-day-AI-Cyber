# prompt: I want to show visually how linier regression protocols in ML take a dataset and pick the best slope and intersect fro the data. Please 1. create a dataset with some randomness what plots number of bedrooms in a house vs price, Ill give you a few examples: 1 bedroom $90,000, 2 bedroom $150000, 3 bedrooms 200000 4 bedrooms 250000. Now plot 20 houses around these prices.  Then I want you to show an animation for how a linear regression protocol would dray lines and try to match to the best fit. this animation should also highlight the distance between the line and the points and display the mean error. this error should obviously get smaller the closer the line is to the optimal fit. THe slope of the fitting line should work like a real linear regression model and try several slopes as well as different y intercept. I want to accurately show in real life how a ml algorithm would acvtually find the best fit for the data

import numpy as np
import matplotlib.pyplot as plt
import matplotlib.animation as animation
from sklearn.linear_model import LinearRegression
from IPython.display import HTML # Keep this import for displaying the animation
import PIL # Import PIL to ensure it's available

# 1. Create the dataset with randomness
np.random.seed(42)  # for reproducibility

# Base data points
bedrooms = np.array([1, 2, 3, 4])
prices = np.array([90000, 150000, 200000, 250000])

# Create 20 houses around these prices
num_houses = 20
house_bedrooms = np.random.randint(1, 5, size=num_houses)
house_prices = []

for bed in house_bedrooms:
    base_price = prices[np.where(bedrooms == bed)[0][0]]
    # Add randomness around the base price
    price = base_price + np.random.normal(0, 20000)  # Add noise
    house_prices.append(price)

house_prices = np.array(house_prices)

# Ensure the data is in the correct shape for sklearn
X = house_bedrooms.reshape(-1, 1)
y = house_prices

# 2. Plot the initial data (commented out as we will show the animation instead)
# fig, ax = plt.subplots()
# ax.scatter(X, y, label='House Data')
# ax.set_xlabel('Number of Bedrooms')
# ax.set_ylabel('Price ($)')
# ax.set_title('House Price vs. Number of Bedrooms')
# ax.legend()
# plt.show()

# 3. Prepare for animation and linear regression

# Find the optimal slope and intercept using sklearn
model = LinearRegression()
model.fit(X, y)
optimal_slope = model.coef_[0]
optimal_intercept = model.intercept_

# Define the starting point for the animation: a horizontal line at the average price
initial_slope = 0
initial_intercept = np.mean(y) # Start with the average price as the y-intercept

# Define the number of frames for each part of the animation
num_frames_to_optimal = 80 # Frames to reach near optimal
num_frames_overshoot = 20 # Frames to overshoot and return

# Calculate the total number of frames
num_frames = num_frames_to_optimal + num_frames_overshoot

# Define the overshoot percentage (e.g., go 10% beyond the optimal change)
overshoot_percent = 0.50 # 50% overshoot

# Calculate the overshoot targets for slope and intercept
# This goes slightly beyond the optimal values in the direction they moved from the initial guess
overshoot_slope_target = optimal_slope + (optimal_slope - initial_slope) * overshoot_percent
overshoot_intercept_target = optimal_intercept + (optimal_intercept - initial_intercept) * overshoot_percent


# Create the animation sequences
# Part 1: From initial to near optimal
animated_slopes_part1 = np.linspace(initial_slope, optimal_slope, num_frames_to_optimal)
animated_intercepts_part1 = np.linspace(initial_intercept, optimal_intercept, num_frames_to_optimal)

# Part 2: From optimal to overshoot target and back to optimal
# This creates a sequence that goes slightly past optimal and then returns
animated_slopes_part2_to_overshoot = np.linspace(optimal_slope, overshoot_slope_target, num_frames_overshoot // 2)
animated_slopes_part2_back_to_optimal = np.linspace(overshoot_slope_target, optimal_slope, num_frames_overshoot - (num_frames_overshoot // 2)) # Ensure total frames add up
animated_slopes_part2 = np.concatenate((animated_slopes_part2_to_overshoot, animated_slopes_part2_back_to_optimal))

animated_intercepts_part2_to_overshoot = np.linspace(optimal_intercept, overshoot_intercept_target, num_frames_overshoot // 2)
animated_intercepts_part2_back_to_optimal = np.linspace(overshoot_intercept_target, optimal_intercept, num_frames_overshoot - (num_frames_overshoot // 2)) # Ensure total frames add up
animated_intercepts_part2 = np.concatenate((animated_intercepts_part2_to_overshoot, animated_intercepts_part2_back_to_optimal))


# Combine the two parts of the animation sequences
animated_slopes = np.concatenate((animated_slopes_part1[:-1], animated_slopes_part2)) # Exclude the last frame of part1 to avoid duplicate at optimal
animated_intercepts = np.concatenate((animated_intercepts_part1[:-1], animated_intercepts_part2)) # Exclude the last frame of part1

# Update the total number of frames to match the new sequence length
num_frames = len(animated_slopes)

# Function to calculate Mean Squared Error (MSE) - Keep this function as it's correct
def mean_squared_error(y_true, y_pred):
    return np.mean((y_true - y_pred)**2)

# Function to update the plot for each frame
def update(frame):
    ax.clear() # Clear the previous frame artists

    ax.scatter(X, y, label='House Data')

    current_slope = animated_slopes[frame]
    current_intercept = animated_intercepts[frame]

    # Calculate the predicted prices for the current line
    y_pred = current_slope * X + current_intercept # y_pred is (20, 1)


    # Plot the current regression line
    # Use the full range of X for plotting the line to ensure it spans the plot
    #x_plot = np.array([X.min(), X.max()]).reshape(-1, 1)
    x_plot = np.linspace(0, 7, 100).reshape(-1, 1)
    y_plot = current_slope * x_plot + current_intercept
    ax.plot(x_plot, y_plot, color='red', label=f'Line (Frame {frame+1})')
    y_plot = current_slope * x_plot + current_intercept
    ax.plot(x_plot, y_plot, color='red', label=f'Line (Frame {frame+1})')
    # Optional visual cue for extrapolation
    ax.axvline(x=5, color='blue', linestyle=':', label='Training Data Limit')
    ax.set_xlim(0, 7)

    # Highlight the distance (residuals) with vertical lines
    for i in range(len(X)):
        # Access the scalar values from X[i] and y_pred[i]
        # Ensure y_pred[i] is also treated as a scalar by taking the first element
        ax.plot([X[i][0], X[i][0]], [y[i], y_pred[i][0]], color='gray', linestyle='--', linewidth=1)


    # Calculate and display the current Mean Squared Error
    # Ensure y and y_pred have compatible shapes for subtraction
    # Reshape y to (20, 1) to match y_pred's shape
    mse = mean_squared_error(y.reshape(-1, 1), y_pred) # Calculate MSE with reshaped y

    # Use a consistent position for the text display
    ax.text(0.05, 0.95, f'MSE: {mse:.2f}', transform=ax.transAxes, fontsize=10,
            verticalalignment='top', bbox=dict(boxstyle='round,pad=0.5', fc='wheat', alpha=0.5))

    ax.set_xlabel('Number of Bedrooms')
    ax.set_ylabel('Price ($)')
    ax.set_title('Linear Regression Simulation')
    ax.legend()

    # Set plot limits based on data range to keep the view consistent
    #ax.set_ylim(y.min() - 20000, y.max() + 20000)
    ax.set_ylim(0,350000)
    # ax.set_xlim(X.min() - 0.5, X.max() + 0.5)
    # Optional visual cue for extrapolation
    ax.axvline(x=5, color='blue', linestyle=':', label='Training Data Limit')
    ax.set_xlim(0, 7)

# Create the figure and axes for the animation
# Re-create the figure and axes since we commented out the initial plot's plt.show()
fig, ax = plt.subplots()

# Create the animation
# Note: Pass fig and ax to FuncAnimation
ani = animation.FuncAnimation(fig, update, frames=num_frames, repeat=False)

